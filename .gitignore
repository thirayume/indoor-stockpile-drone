# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/
.ruff_cache/

# Node
node_modules/
web/dist/

# Prepared dataset images (symlink/copy created by dataset_utils prepare)
data/opensfm_project/images

# Downloaded reference material (refresh with: python tools/download_refs.py)
docs/opensfm/

# OpenSfM pipeline outputs (regenerated from images/) — everything in the
# project folder except config.yaml and an optional real gcp_list.txt
data/opensfm_project/*
!data/opensfm_project/config.yaml
!data/opensfm_project/gcp_list.txt

# data/odm is the ODMdata git submodule; dataset repos cloned inside it are
# untracked there and invisible to this repo (submodule ignore = untracked).

# Local environment configuration (ports etc., read by docker compose).
# .env.example is committed as the template; the real .env is per-machine.
.env
!.env.example

# Claude Code local settings
.claude/

# Editors / OS
.vscode/
.idea/
Thumbs.db
.DS_Store
