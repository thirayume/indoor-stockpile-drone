# Copy this to `.env` (same folder as docker-compose.yml) to match the
# reference setup. docker compose reads `.env` automatically; `.env` itself is
# gitignored so each machine keeps its own ports.
#
#   cp .env.example .env        # macOS / Linux / Git Bash
#   copy .env.example .env      # Windows cmd
#
# --- Host ports -------------------------------------------------------------
# Web UI port. The reference machine uses 5273 because 5173 was taken by
# another local app; change it to whatever is free for you (5173 is fine on a
# clean machine).
WEB_PORT=5273
# Backend/API port (defaults to 8000 when unset).
# BACKEND_PORT=8000

# --- OpenSfM overlay (real reconstructions) ---------------------------------
# Always layer docker-compose.opensfm.yml on top of the base compose file, so
# a plain `docker compose up -d` gives the backend the OpenSfM CLI AND a
# writable data mount. Without this the data mount is read-only and OpenSfM
# fails with "[Errno 30] Read-only file system" on config.yaml.
#
# NOTE: the first build with the overlay compiles OpenSfM from source (long,
# one-time). Drop these two lines if you only want the lightweight backend
# (Open3D volume/segmentation on a prebuilt point cloud, no reconstruction).
COMPOSE_PATH_SEPARATOR=;
COMPOSE_FILE=docker-compose.yml;docker-compose.opensfm.yml

# --- ML segmentation ---------------------------------------------------------
# The backend image installs torch (CPU) + ultralytics for the ML ("AI
# auto-detect") segmentation mode by default. Set to false for a slimmer
# image without that mode. Model weights download on first use into
# data/models/ (needs the writable mount from the OpenSfM overlay above).
# INSTALL_ML=true
